# SPDX-License-Identifier: PMPL-1.0-or-later
# EditorConfig — https://editorconfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# ReScript source files
[*.{res,resi}]
indent_style = space
indent_size = 2

# JavaScript (compiled output + glue)
[*.{js,mjs}]
indent_style = space
indent_size = 2

# JSON and YAML configuration
[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

# Guile Scheme machine-readable files
[*.scm]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Containerfile / Justfile
[{Containerfile,Justfile,Mustfile}]
indent_style = space
indent_size = 2

# Markdown / AsciiDoc
[*.{md,adoc}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
